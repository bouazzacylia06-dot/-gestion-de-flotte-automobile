{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "barchart", "name": "Bar chart", "version": "" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "" }
  ],
  "title": "Flotte - API SLI/SLO",
  "uid": "flotte-api-sli-slo",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(flotte_http_requests_total, exported_service)",
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": ["$__all"]
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "RPS par service",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (exported_service) (rate(flotte_http_requests_total{exported_service=~\"$service\"}[5m]))",
          "legendFormat": "{{exported_service}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Débit 5xx/s par service",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (exported_service) (rate(flotte_http_requests_total{exported_service=~\"$service\", status=~\"5..\"}[5m]))",
          "legendFormat": "{{exported_service}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Ratio d'erreur 5xx",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (exported_service) (rate(flotte_http_requests_total{exported_service=~\"$service\", status=~\"5..\"}[5m])) / clamp_min(sum by (exported_service) (rate(flotte_http_requests_total{exported_service=~\"$service\"}[5m])), 0.001)",
          "legendFormat": "{{exported_service}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Latence p95 (s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (exported_service, le) (rate(flotte_http_request_duration_seconds_bucket{exported_service=~\"$service\"}[5m])))",
          "legendFormat": "{{exported_service}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "barchart",
      "title": "Top 10 routes (RPS)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by (exported_service, route, method) (rate(flotte_http_requests_total{exported_service=~\"$service\"}[5m])))",
          "legendFormat": "{{exported_service}} {{method}} {{route}}"
        }
      ]
    }
  ]
}
